# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for SMTP/IMAP passwords stored in DB (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-char-random-key

# AI
ANTHROPIC_API_KEY=your-anthropic-key

# Web research (https://linkup.so)
LINKUP_API_KEY=your-linkup-key

# Contact enrichment (https://fullenrich.com)
FULLENRICH_API_KEY=your-fullenrich-key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Tracking (generate with: openssl rand -base64 32)
TRACKING_SECRET=your-hmac-tracking-secret

# App URL (used for tracking pixel, OAuth callbacks)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
